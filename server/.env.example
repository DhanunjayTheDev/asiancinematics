# Server Environment Variables

NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb+srv://asiancinematics:asiancinematics123@asiancinematics.rhyvrke.mongodb.net/asiancinematics_db?appName=asiancinematics
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/asiancinematics

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cookie
COOKIE_SECRET=your-cookie-secret-change-in-production

# CORS
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Email (SMTP / SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@asiancinematics.com
FROM_NAME=Asian Cinematics

# WhatsApp API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloud Storage (GCP)
GCP_PROJECT_ID=
GCP_BUCKET_NAME=
GCP_KEY_FILE=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# Feature Flags
FEATURE_WHATSAPP_NOTIFICATIONS=false
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_PAYMENT_GATEWAY=false
FEATURE_SITE_VISITS=true
